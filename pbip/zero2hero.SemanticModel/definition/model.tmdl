model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Reference Queries'

	annotation PBI_QueryGroupOrder = 0

queryGroup Parameters

	annotation PBI_QueryGroupOrder = 1

queryGroup 'Merge Operations'

	annotation PBI_QueryGroupOrder = 2

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Customer","Geography","Sales","Product","SubCategory","Category","Date","YearList","PYearStart","PYearEnd","Exported Data","Right-Lookup","Right-Merge","Left-Exclusion","Left Anti-Merge","Right-Anti Task","Right Anti Delta","Right Anti-Merge","Online Sales","Tele Sales","Inner Merge"]

annotation PBI_ProTooling = ["DevMode"]

ref table Customer
ref table Sales
ref table Product
ref table Date

ref cultureInfo en-US

